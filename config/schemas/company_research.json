{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["company_domain", "company_name", "industry", "competitors", "excellence", "shortcomings", "aspirations"],
  "properties": {
    "company_domain": {
      "type": "string",
      "format": "hostname"
    },
    "company_name": {
      "type": "string",
      "minLength": 1
    },
    "industry": {
      "type": "string",
      "minLength": 1
    },
    "headquarters": {
      "type": "string"
    },
    "founded": {
      "type": "string"
    },
    "competitors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "excellence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["area", "description"],
        "properties": {
          "area": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "shortcomings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["area", "description"],
        "properties": {
          "area": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "public_acknowledgment": {
            "type": "string"
          }
        }
      }
    },
    "aspirations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["statement", "source_url"],
        "properties": {
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          },
          "timeframe": {
            "type": "string"
          }
        }
      }
    },
    "recent_news": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["headline", "date", "summary"],
        "properties": {
          "headline": {
            "type": "string",
            "minLength": 1
          },
          "date": {
            "type": "string"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "culture_values": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["value", "description"],
        "properties": {
          "value": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}