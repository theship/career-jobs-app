# ---- Rename this file to `.env` and fill in real values (DO NOT COMMIT `.env`) ----

# Daytona CLI API key (Sandbox or Account key)
DAYTONA_API_KEY=dkp_xxxxxxxxxxxxxxxxx

# GitHub fine-grained Personal Access Token (repo-scoped)
# Permissions: Contents (RW), Workflows (RW)
GH_PAT=ghp_xxxxxxxxxxxxxxxxx

# Anthropic API key for Claude Code (install Claude Code in Daytona sandbox)
ANTHROPIC_API_KEY=changeme

# --- Supabase Configuration ---
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- OpenAI Configuration ---
OPENAI_API_KEY=sk-...

# --- Redis Configuration (REQUIRED) ---
# Redis connection URL for caching and security features
REDIS_URL=redis://localhost:6379/0

# --- Security Configuration ---
# HMAC secret for request signing (generate with: openssl rand -hex 32)
HMAC_SECRET=your-hmac-secret-key-here

# Shared secret between Next.js and FastAPI for service-to-service auth
# Generate with: openssl rand -base64 32
SERVICE_SECRET=your-secure-random-string-here

# --- App configuration (optional) ---
SS_API_BASE_URL=https://api.ss-jobs.com/
SS_API_KEY=__REPLACE_ME__

# Optional: VS Code Web / code-server password if you enable it
# CS_PASSWORD=daytona

# Optional: local defaults
NODE_ENV=development
PORT=3000
